{
  "name": "@master4n/decorators",
  "version": "2.0.5",
  "description": "AI-friendly TypeScript decorators for Node/backend apps, in ten families: Inject (config & value injection), Guard (validation), Shape (transforms), Shield (access control & secret redaction), Flow (resilience — retry/timeout/circuit-breaker/rate-limit/cache), Insight (observability), Model (data classes), Route (Express REST controllers), Agent (LLM tools, guardrails, idempotency), and Craft (class/method ergonomics). One decorator replaces a block of code.",
  "main": "./dist/commonjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/commonjs/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./config": {
      "import": "./dist/esm/config.js",
      "require": "./dist/commonjs/config.cjs",
      "types": "./dist/config.d.ts"
    },
    "./winston": {
      "import": "./dist/esm/winston.js",
      "require": "./dist/commonjs/winston.cjs",
      "types": "./dist/winston.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "build": "npm run clean && rollup --config",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:dist": "npm run build && jest --config jest.dist.config.mjs",
    "publish:dryrun": "npm publish ./dist --dry-run",
    "publish:npm": "npm publish ./dist --access public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Master4Novice/decorators.git"
  },
  "keywords": [
    "decorators",
    "typescript",
    "nodejs",
    "config",
    "configuration",
    "value-injection",
    "dependency-injection",
    "env",
    "dotenv",
    "yaml",
    "validation",
    "transform",
    "express",
    "rest-api",
    "controller",
    "routing",
    "retry",
    "timeout",
    "circuit-breaker",
    "rate-limit",
    "cache",
    "memoize",
    "debounce",
    "observability",
    "redaction",
    "llm",
    "tools",
    "agent",
    "ai-agents",
    "ai-friendly",
    "boilerplate",
    "typescript-decorators",
    "method-decorator",
    "retry-decorator",
    "circuit-breaker",
    "rate-limit-decorator",
    "validation-decorator",
    "resilience",
    "secret-redaction",
    "idempotency",
    "zero-dependency"
  ],
  "author": "dwivna",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Master4Novice/decorators/issues"
  },
  "homepage": "https://github.com/Master4Novice/decorators#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "directory": "dist",
    "access": "public"
  },
  "peerDependencies": {
    "config": "^3.3.9 || ^4.0.0",
    "winston": "^3.11.0"
  },
  "peerDependenciesMeta": {
    "config": {
      "optional": true
    },
    "winston": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/config": "^3.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "config": "^3.3.9",
    "winston": "^3.11.0",
    "jest": "^29.7.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.4",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-dts": "^6.4.1",
    "ts-jest": "^29.3.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3"
  },
  "contributors": [
    {
      "name": "dwivna"
    }
  ]
}
