{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": ".",
    "target": "ES2020",
    "useDefineForClassFields": false,
    "verbatimModuleSyntax": false,
    "outDir": "./dist/.ts-jest",
    "types": ["jest", "node"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
